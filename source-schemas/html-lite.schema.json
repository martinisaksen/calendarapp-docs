{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://martinisaksen.github.io/calendarapp-docs/source-schemas/html-lite.schema.json",
  "title": "CalendarApp HtmlLite schemaDefinition",
  "description": "Contributor-facing JSON Schema for CalendarApp HtmlLite source schemas.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventCardSelector",
    "mappings"
  ],
  "properties": {
    "eventCardSelector": {
      "type": "string",
      "minLength": 1
    },
    "mappings": {
      "$ref": "#/$defs/htmlMappings"
    },
    "detailPage": {
      "$ref": "#/$defs/detailPageConfig"
    },
    "eventEnrichment": {
      "$ref": "#/$defs/eventEnrichment"
    },
    "multiDateExpansion": {
      "$ref": "#/$defs/multiDateExpansion"
    },
    "pagination": {
      "$ref": "#/$defs/htmlPaginationConfig"
    },
    "validation": {
      "$ref": "#/$defs/validationRules"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "multiDateExpansion": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "multiDateExpansion": {
            "required": ["sourceField", "limits"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "eventEnrichment": {
            "properties": {
              "enabled": { "const": true },
              "parser": { "const": "HtmlLite" }
            },
            "required": ["enabled", "parser"]
          }
        }
      },
      "then": {
        "properties": {
          "eventEnrichment": {
            "required": ["htmlLiteMappings"]
          }
        }
      }
    }
  ],
  "$defs": {
    "mappingValue": {
      "type": "string",
      "minLength": 1
    },
    "htmlMappings": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "id": { "$ref": "#/$defs/mappingValue" },
        "title": { "$ref": "#/$defs/mappingValue" },
        "startTime": { "$ref": "#/$defs/mappingValue" },
        "endTime": { "$ref": "#/$defs/mappingValue" },
        "startDate": { "$ref": "#/$defs/mappingValue" },
        "endDate": { "$ref": "#/$defs/mappingValue" },
        "description": { "$ref": "#/$defs/mappingValue" },
        "location": { "$ref": "#/$defs/mappingValue" },
        "venueName": { "$ref": "#/$defs/mappingValue" },
        "venueAddress": { "$ref": "#/$defs/mappingValue" },
        "url": { "$ref": "#/$defs/mappingValue" },
        "imageUrl": { "$ref": "#/$defs/mappingValue" },
        "recurrenceRule": { "$ref": "#/$defs/mappingValue" },
        "timeZone": { "$ref": "#/$defs/mappingValue" },
        "timezone": { "$ref": "#/$defs/mappingValue" }
      }
    },
    "detailPageConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "linkSelector": {
          "type": "string"
        },
        "detailMappings": {
          "$ref": "#/$defs/htmlMappings"
        },
        "occurrenceSelector": {
          "type": "string"
        },
        "occurrenceMappings": {
          "$ref": "#/$defs/htmlMappings"
        }
      }
    },
    "multiDateExpansion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "sourceField": {
          "type": "string",
          "minLength": 1,
          "enum": ["startTime", "startDate"]
        },
        "defaultTime": {
          "type": "string",
          "minLength": 1
        },
        "defaultTimeZone": {
          "type": "string",
          "minLength": 1
        },
        "fallbackMode": {
          "type": "string",
          "enum": ["legacySingle", "skipCard", "LegacySingle", "SkipCard"]
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxOccurrencesPerCard", "maxExpandedEventsPerRun", "maxParseFailuresPerCard"],
          "properties": {
            "maxOccurrencesPerCard": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "maxExpandedEventsPerRun": {
              "type": "integer",
              "minimum": 1,
              "maximum": 2000
            },
            "maxParseFailuresPerCard": {
              "type": "integer",
              "minimum": 0,
              "maximum": 20
            }
          }
        }
      }
    },
    "htmlPaginationConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["NextLink", "QueryIncrement", "PathIncrement", "FixedUrls", "nextLink", "queryIncrement", "pathIncrement", "fixedUrls"]
        },
        "nextPageSelector": {
          "type": "string"
        },
        "parameter": {
          "type": "string"
        },
        "start": {
          "type": "integer"
        },
        "step": {
          "type": "integer"
        },
        "pathTemplate": {
          "type": "string"
        },
        "urls": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "maxPages": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "validationRules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minEventsPerFetch": {
          "type": "integer"
        },
        "maxEventsPerFetch": {
          "type": "integer"
        },
        "requiredFields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "eventEnrichment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "parser"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "parser": {
          "type": "string",
          "enum": ["GenericHtml", "HtmlLite"]
        },
        "maxFetchesPerRun": {
          "type": "integer",
          "minimum": 0
        },
        "sameHostOnly": {
          "type": "boolean"
        },
        "htmlLiteMappings": {
          "$ref": "#/$defs/htmlMappings"
        }
      }
    }
  }
}