{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Source Schema Submission Request",
  "description": "Valid payload for both POST /api/source-schemas/test-fetch and POST /api/source-schemas/community-submissions",
  "type": "object",
  "required": ["type", "feedUrl", "schemaDefinition", "name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name of the calendar source",
      "examples": ["La Center Community Calendar", "Seattle Parks & Recreation Events"]
    },
    "description": {
      "type": "string",
      "description": "What this source publishes; 1-2 sentences",
      "examples": ["Public events from La Center, WA", "Official city events and announcements"]
    },
    "type": {
      "type": "string",
      "enum": ["Ics", "Rss", "JsonApi", "HtmlLite"],
      "description": "The source type detected from the feed"
    },
    "feedUrl": {
      "type": "string",
      "format": "uri",
      "description": "Absolute URL of the calendar feed (HTTP or HTTPS)",
      "examples": ["https://example.org/calendar.ics", "https://example.org/events/feed.rss"]
    },
    "schemaDefinition": {
      "type": "string",
      "description": "JSON schema definition as a STRING (not an object). For Ics, typically '{}' or validation-only. For other types, includes parsing rules like eventArrayPath and mappings.",
      "examples": ["{}", "{\"extractionRules\":{\"title\":\"title\",\"startTime\":\"pubDate\"}}"]
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata about the source. Use ONLY these fields; custom fields are not allowed.",
      "properties": {
        "location": {
          "type": "string",
          "description": "Geographic location: city, state, region, or venue name",
          "examples": ["Seattle, WA", "Pike Place Market", "Washington State"]
        },
        "region": {
          "type": "string",
          "description": "State or region code",
          "examples": ["WA", "CA", "Pacific Northwest"]
        },
        "category": {
          "type": "string",
          "description": "Event category",
          "examples": ["community", "government", "entertainment", "education"]
        },
        "language": {
          "type": "string",
          "description": "ISO 639-1 language code",
          "examples": ["en", "es", "fr"]
        },
        "contactEmail": {
          "type": "string",
          "format": "email",
          "description": "Email for questions about this source"
        },
        "estimatedEventCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Approximate number of events published per month"
        }
      },
      "additionalProperties": false
    },
    "calendarStrategyOverride": {
      "type": "string",
      "enum": ["Auto", "Exclusive", "Merge"],
      "description": "Optional override for how events are calendared (default: Auto)"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "name": "La Center Calendar",
      "description": "Public ICS feed from La Center, WA",
      "type": "Ics",
      "feedUrl": "https://calendar.google.com/calendar/ical/lacentercalendar%40gmail.com/public/basic.ics",
      "schemaDefinition": "{}",
      "metadata": {
        "location": "La Center, WA",
        "region": "WA",
        "category": "community"
      }
    },
    {
      "name": "Example Recreation Events",
      "description": "Community events from Example Org",
      "type": "Rss",
      "feedUrl": "https://example.org/events/feed.rss",
      "schemaDefinition": "{\"extractionRules\":{\"title\":\"title\",\"startTime\":\"pubDate\"},\"validation\":{\"requiredFields\":[\"title\",\"startTime\"]}}",
      "metadata": {
        "location": "Example City",
        "region": "WA",
        "category": "community",
        "language": "en"
      }
    }
  ]
}
